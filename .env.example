# API configuration
API_BASE_URL=http://sample.com/api/v1
TARGET_API_KEY=YOUR_ASSIGNED_API_KEY

# Set to 1 to run fully local end-to-end testing (no external API calls)
USE_MOCK_API=0
MOCK_TOTAL_EVENTS=50000
MOCK_DEFAULT_PAGE_SIZE=5000
MOCK_RATE_LIMIT_RPS=200

# Pagination + throughput tuning
API_PAGE_SIZE=5000
API_RATE_LIMIT_REQUESTS=10
API_RATE_LIMIT_WINDOW_SECONDS=10
API_MIN_TIME_MS=1500
API_MAX_RETRIES=6
API_TIMEOUT_MS=30000

# Ingestion orchestration settings
INGESTION_RUN_ID=datasync-ingestion-main
INGESTION_WORKFLOW_ID=datasync-ingestion-workflow
INGESTION_ACTIVITY_PARALLELISM=2
INGESTION_WORKER_CONCURRENCY=2
INGESTION_MAX_SEGMENT_RETRIES=8
INGESTION_STALE_SEGMENT_SECONDS=180
INGESTION_EXPECTED_EVENTS=3000000
# Cursor sharding (used only in cursor strategy). Set both window vars to enable multi-shard cursor ingestion.
INGESTION_CURSOR_SHARDS=2
INGESTION_CURSOR_WINDOW_START=
INGESTION_CURSOR_WINDOW_END=
# 0 means unlimited; set small value (e.g. 3) for real-API smoke tests.
INGESTION_TEST_MAX_API_CALLS=0
INGESTION_PROGRESS_LOG_INTERVAL_MS=5000
